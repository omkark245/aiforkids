---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
	title="Privacy Policy | AI For Kidds"
	description="Read the static-site privacy policy for AI For Kidds and how contact actions work through WhatsApp and email."
	path="/privacy-policy"
>
	<section class="page-hero">
		<div class="shell">
			<div class="page-hero-panel centered">
				<span class="eyebrow">Privacy Policy</span>
				<h1>Privacy policy for the AI For Kidds static website.</h1>
			</div>
		</div>
	</section>

	<section class="page-section">
		<div class="shell">
			<div class="legal-card">
				<h3>1. Website model</h3>
				<p>
					AI For Kidds is a static website. It does not collect information through web forms, student accounts, or
					progress dashboards in this version.
				</p>
				<h3>2. Contact actions</h3>
				<p>
					When you use a WhatsApp, phone, email, or map link, you are leaving the website and using a third-party or
					direct communication channel.
				</p>
				<h3>3. Analytics and cookies</h3>
				<p>
					This version is designed to minimize tracking and avoid unnecessary scripts. If analytics are added later,
					this policy should be updated accordingly.
				</p>
				<h3>4. Content use</h3>
				<p>
					All static learning content, study notes, and teaching resources remain the intellectual property of AI For
					Kidds unless otherwise stated.
				</p>
			</div>
		</div>
	</section>
</BaseLayout>
