---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
	title="Terms | AI For Kidds"
	description="Read the terms for using the AI For Kidds static learning website."
	path="/terms"
>
	<section class="page-hero">
		<div class="shell">
			<div class="page-hero-panel centered">
				<span class="eyebrow">Terms</span>
				<h1>Terms for using the AI For Kidds website.</h1>
			</div>
		</div>
	</section>

	<section class="page-section">
		<div class="shell">
			<div class="legal-card">
				<h3>1. Informational use</h3>
				<p>The website provides static educational information, grade pages, practice suggestions, and teacher support material.</p>
				<h3>2. No guaranteed outcomes</h3>
				<p>Learning outcomes depend on classroom use, effort, and how static resources are interpreted and applied.</p>
				<h3>3. External channels</h3>
				<p>WhatsApp, phone, and email communications are separate channels and may be subject to third-party terms.</p>
				<h3>4. Content updates</h3>
				<p>We may revise grade pages, resource lists, and legal content as the website evolves.</p>
			</div>
		</div>
	</section>
</BaseLayout>
