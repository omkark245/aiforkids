---
import { navigation } from '../data/site';
import WhatsAppButton from './WhatsAppButton.astro';

const pathname = Astro.url.pathname;
---

<header class="site-header">
	<div class="shell header-shell">
		<a class="brand" href="/">
			<span class="brand-mark">AI</span>
			<span class="brand-copy">
				<strong>AI For Kidds</strong>
				<small>Grade-first AI learning</small>
			</span>
		</a>
		<nav class="site-nav" aria-label="Primary navigation">
			{navigation.map((item) => (
				<a class:list={['nav-link', pathname === item.href && 'is-active']} href={item.href}>
					{item.label}
				</a>
			))}
		</nav>
		<div class="header-cta">
			<WhatsAppButton label="Get Started" message="Hi AI For Kidds, I want help choosing the right AI learning page." />
		</div>
	</div>
</header>
